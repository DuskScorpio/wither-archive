  "records": {
    "description": "Snow farm that uses a wither to break snow layers and crafts them into snow blocks.",
    "versions": "1.21.5+",
    "rates": [
      "Snow Block: 7200/h"
    ],
    "build": "- Make sure that the entire farm is inside 1 chunk\n\nFollow the schematics in this order: \n1  - Summoning\n2 - Snow Golems Alignment\n3 - Bedrockless Wither Snow Block Farm",
    "considerations": [
      "Only works in the overworld"
    ],
    "notes": [
      "Do not build in biomes with a base temperature greater than 0. Add a roof if you're building it in a biome in which it can rain",
      "Nametag the creaking"
    ]
  },
